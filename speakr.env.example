# speakr configuration — points speakr at the shim + your LLM backend
APP_PORT=8899
APP_HOST=0.0.0.0
APP_DATA_DIR=/data

# Transcription: routed through the mossland-shim
TRANSCRIPTION_CONNECTOR=openai_transcribe
TRANSCRIPTION_BASE_URL=http://mossland-shim:8000/v1
TRANSCRIPTION_API_KEY=local-shim-does-not-validate-this
TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize
TRANSCRIPTION_REQUEST_TIMEOUT=1800

# LLM backend (any OpenAI-compatible endpoint)
TEXT_MODEL_PROVIDER=openai
TEXT_MODEL_BASE_URL=https://ollama.com/v1
TEXT_MODEL_API_KEY=your-ollama-api-key
TEXT_MODEL_NAME=glm-5.2
TITLE_MODEL_NAME=glm-5.2
SUMMARY_MODEL_NAME=glm-5.2

# Reasoning model token budgets (see speakr issue #264)
TITLE_MAX_TOKENS=16000
SUMMARY_MAX_TOKENS=16000
CHAT_MAX_TOKENS=16000
EVENT_MAX_TOKENS=16000
LLM_REQUEST_TIMEOUT=600

DISABLE_LOCAL_WHISPER=true
ENABLE_CHUNKING=false
AUDIO_COMPRESS_UPLOADS=false
