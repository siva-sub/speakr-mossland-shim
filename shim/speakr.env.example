# speakr environment.
# These mirror the speakr docs:
#   https://murtaza-nasir.github.io/speakr/getting-started/installation
#
# The crucial piece is TRANSCRIPTION_BASE_URL pointing at our shim, plus
# TRANSCRIPTION_CONNECTOR=openai (which is what tells speakr to use the
# OpenAI-shaped multipart upload path).

# --- Core speakr config ---
APP_PORT=8899
APP_HOST=0.0.0.0
APP_DATA_DIR=/data

# --- Transcription: point speakr at the shim ---
TRANSCRIPTION_CONNECTOR=openai
TRANSCRIPTION_BASE_URL=http://mossland-shim:8000/v1
TRANSCRIPTION_API_KEY=local-shim-does-not-validate-this
TRANSCRIPTION_MODEL=moss-transcribe-diarize
# The shim's poll timeout is 600s; speakr's request timeout should be longer.
TRANSCRIPTION_REQUEST_TIMEOUT=700

# --- LLM: choose what you already use (Ollama, OpenAI, OpenRouter, etc.) ---
# These are the env vars speakr reads; fill in what you have.
TEXT_MODEL_PROVIDER=openai
TEXT_MODEL_API_KEY=
TEXT_MODEL_NAME=
TEXT_MODEL_BASE_URL=
TITLE_MODEL_NAME=
SUMMARY_MODEL_NAME=

# --- Disable the bundled Whisper path (we replaced it with the shim) ---
DISABLE_LOCAL_WHISPER=true
