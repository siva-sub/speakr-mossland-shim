# Mossland/MOSI ASR connector for speakr
# Get your API key at https://studio.mosi.cn/app/api-keys

# --- Core config ---
TRANSCRIPTION_CONNECTOR=mossland
TRANSCRIPTION_API_KEY=your-mossland-api-key-here

# Model name (auto-discovered from GET /v1/models; validated at init).
# If unset, defaults to moss-transcribe-diarize.
# When new MOSS models are released, they appear automatically — no code change needed.
# TRANSCRIPTION_MODEL=moss-transcribe-diarize

# API base URL (default: https://api.mosi.cn)
# MOSSLAND_BASE_URL=https://api.mosi.cn

# --- Transport mode (controls fallback behavior) ---
# auto     = SSE streaming → async poll → 5-min chunking (default, cascading)
# stream   = SSE streaming only (no fallback, fastest)
# async    = async polling only (no streaming, no chunking)
# chunk    = 5-min chunking only (most conservative, speaker labels may fragment)
# MOSSLAND_TRANSPORT=auto

# --- Model version ---
# Required for moss-transcribe-diarize (sent automatically when the model needs it).
# MOSSLAND_VERSION=v20260410-streamparam-20260703

# --- Token budget ---
# If set, uses this fixed sampling_params JSON for all requests.
# If unset, scales max_new_tokens with audio duration (see MOSSLAND_TOKENS_PER_SEC).
# MOSSLAND_SAMPLING_PARAMS={"max_new_tokens":65536,"temperature":0}

# Tokens per audio second for duration-scaled budget (default: 10).
# Dense multi-speaker meetings use ~4.5 tokens/sec, so 10 gives 2x headroom.
# Lower for sparse audio (podcasts with silence); raise for dense overlapping speech.
# MOSSLAND_TOKENS_PER_SEC=10

# Maximum audio duration the connector will accept (seconds, default: 5400 = 90 min).
# Audio longer than this is rejected with a clear error before sending to the API.
# MOSSLAND_MAX_AUDIO_DURATION=5400

# --- Polling config (async fallback mode) ---
# MOSSLAND_POLL_INTERVAL=5.0
# MOSSLAND_POLL_TIMEOUT=1800

# --- Chunking config (last-resort fallback) ---
# MOSSLAND_CHUNK_DURATION=300

# --- Timestamp sanitization (sglang-omni #1034) ---
# Clamps segment timestamps that exceed audio_duration + 5s tolerance.
# MOSSLAND_SANITIZE_TIMESTAMPS=true

# The connector handles long audio internally (up to 90 min, single-pass).
# Disable speakr's app-level chunking to avoid double-chunking.
ENABLE_CHUNKING=false
